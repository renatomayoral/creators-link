# splitfy-specific environment variables. Root ../../.env is the actual
# source of truth in the monorepo dev environment — this file documents what
# splitfy needs so the app can be extracted with a self-contained .env later.

# Own database — deliberately separate from the creators-link DATABASE_URL,
# so splitfy's tables (including its own Better Auth user/session/account)
# never collide with apps/web's.
SPLITFY_DATABASE_URL=postgres://user:password@host:5432/splitfy

# Hot signer that receives ERC-20 allowances from subscribers and executes
# the pull + split each billing cycle. MUST be a Secret Manager secret in
# production deploys, never committed or logged.
OPERATOR_PRIVATE_KEY=0x...

# Where each merchant's platform take-rate lands by default, if the merchant
# row itself has no platformWallet set.
PLATFORM_WALLET_ADDRESS=0x...

# Optional per-chain RPC overrides (public defaults are used otherwise).
RPC_URL_POLYGON=
RPC_URL_ARBITRUM=
RPC_URL_BASE=
RPC_URL_BSC=

# Shared secret for the /api/cron/charge-due route (Authorization: Bearer).
CRON_SECRET=

# Public base URL of this splitfy deployment, used to build subscribe links.
SPLITFY_APP_URL=http://localhost:3001

# Better Auth (merchant dashboard at /dashboard — separate accounts from
# apps/web, never shared). Generate a secret with `openssl rand -base64 32`.
SPLITFY_BETTER_AUTH_SECRET=
SPLITFY_BETTER_AUTH_URL=

# WalletConnect (optional — injected wallet connector works without it).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
